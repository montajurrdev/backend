<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="w-full min-h-screen max-h-fit bg-zinc-900 p-10 text-white">
      <div class="w-full flex justify-end">
        <a
          class="px-3 py-2 bg-red-500 rounded-md text-sm mb-5 inline-block"
          href="/logout"
          >Logout</a
        >
      </div>
      <h3 class="text-3xl mb-5">
        <span class="font-light">Hello</span>, <%= user.name %>
      </h3>
      <h5 class="mb-5">you can create a new post</h5>
      <form action="/post" method="post">
        <textarea
          name="content"
          id=""
          placeholder="what's on your mind"
          class="p-3 outline-none w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md"
        ></textarea>
        <input
          type="submit"
          value="Create new post"
          class="text-sm px-3 py-2 w-40 bg-blue-500 block rounded-md mt-2"
        />
      </form>

      <div class="posts mt-20">
        <h3 class="text-xl text-zinc-400">Your Posts</h3>
        <div class="postContainer mt-5">
            <% user.posts.forEach(function(post){ %>
          <div class="post w-1/3 p-4 border-[1px] mb-4 border-zinc-700 bg-zinc-800  rounded-md">
            <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
            <p class="text-sm tracking-tight">
              <%= post.content %>
            </p>
            <div class="btns flex gap-10 mt-5">
                <a class="text-blue-500" href="">Like</a>
                <a class="text-zinc-600" href="">edit</a>

            </div>
          </div>
            <% }) %>


        </div>
      </div>
    </div>
  </body>
</html>
