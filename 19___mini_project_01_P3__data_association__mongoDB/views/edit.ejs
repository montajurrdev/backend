<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="w-full min-h-screen max-h-fit bg-zinc-900 p-10 text-white">
      <div class="w-full flex justify-end">
        <a
          class="px-3 py-2 bg-red-500 rounded-md text-sm mb-5 inline-block"
          href="/logout"
          >Logout</a
        >
      </div>

      <h5 class="mb-5">Edit your post</h5>
      <form action="/update/<%= post._id %>" method="post">
        <textarea
          name="content"
          placeholder="what's on your mind"
          class="p-3 outline-none w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md"
        ><%= post.content %></textarea>
        <input
          type="submit"
          value="Update post"
          class="text-sm px-3 py-2 w-40 bg-yellow-500 text-black block rounded-md mt-2"
        />
      </form>
    </div>
  </body>
</html>
