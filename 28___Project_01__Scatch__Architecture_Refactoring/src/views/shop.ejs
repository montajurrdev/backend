    <%- include("partials/header.ejs") %>

         <% if(success.length > 0){%>
      <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-green-500">
        <span class="inline-block mt-1 mb-1 text-white">
          <%= success %>
        </span>
      </div>
    <%} %>
    <div class="w-full h-screen flex items-start p-20">
      <div class="w-1/4 h-screen flex flex-col items-start">
        <div class="flex items-center gap-2">
          <h3>sort</h3>
          <form action="">
            <select class="border-[1px] px-2 py-1" name="sortby">
              <option value="popular">Popular</option>
              <option value="newest">Newest</option>
            </select>
          </form>
        </div>
        <div class="flex flex-col mt-20">
          <a class="block w-fit mb-2" href="">New Collection</a>
          <a class="block w-fit mb-2" href="">All Products</a>
          <a class="block w-fit mb-2" href="">Discounted Products</a>
        </div>
        <div class="flex flex-col mt-32">
          <a href="block w-fit mb-2">Filter by :</a>
          <a href="block w-fit mb-2">Availability</a>
          <a href="block w-fit mb-2">Discount</a>
        </div>
      </div>
      <div class="w-3/4 flex flex-col h-screen">
        <div class="flex items-start gap-5 flex-wrap">
          <% products.forEach((product)=>{%>            
            <div id="product" class="w-60">
              <div
                class="w-full h-52 flex items-center justify-center bg-[<%= product.bgcolor %>]"
              >
                <img
                  class="h-3/4"
                  src="data:image/png;base64,<%= product.image.toString("base64") %>"
                  alt="This is an image"
                />
              </div>
              <div
                class="flex justify-between bg-[<%= product.panelcolor %>] items-center px-4 py-4 text-[<%= product.textcolor %>]"
              >
                <div>
                  <h3><%= product.name %></h3>
                  <h4><%= product.price %></h4>
                </div>
                <a
                  class="w-7 h-7 flex items-center justify-center rounded-full bg-white"
                  href="/addtocart/<%= product._id %>"
                >
                  <i class="ri-add-line"></i>
                </a>
              </div>
            </div>
          <%}) %>


        </div>
      </div>
    </div>

    <%- include("partials/footer.ejs") %>
