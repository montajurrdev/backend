    <%- include("partials/header.ejs") %>


    <div class="w-full min-h-screen flex flex-col">
      <div class="container px-10 py-20 flex flex-grow">
        <div class="w-1/4 flex h-screen flex-col items-start">
          <div class="flex flex-col">
            <a class="block w-fil mb-2" href="">All Products</a>
            <a class="block w-fil mb-2" href="">Create new products</a>
          </div>
        </div>
        <main class="w-3/4 bg-zinc-900 p-8 shadow ml-4">
          <h2 class="text-xl font-bold mb-4">Create New product</h2>
          <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data">
            <div class="mb-6">
              <h3 class="text-lg font-semibold mb-6">Product Details</h3>
              <div class="mb-4">
                <label class="block mb-2 font-medium" for=""
                  >Product Image</label
                >
                <input
                  class="py-2 px-4 rounded"
                  value="Select File"
                  type="file"
                  name="image"
                />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="name"
                  placeholder="Product name"
                />
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="price"
                  placeholder="Product Price"
                />
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="discount"
                  placeholder="Discount Price"
                />
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-6">Panel Details</h3>

              <div class="grid grid-cols-2 gap-4">
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="bgcolor"
                  placeholder="Background Color"
                />
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="panelcolor"
                  placeholder="Panel Color"
                />
                <input
                  class="border-2 border-zinc-600 outline-none p-2 rounded w-full"
                  type="text"
                  name="textcolor"
                  placeholder="Text Color"
                />
              </div>
            </div>
            <input
              class="px-5 py-2 rounded mt-3 bg-blue-500 text-white"
              type="submit"
              value="Create New Product"
            />
          </form>
        </main>
      </div>
    </div>

    <%- include("partials/footer.ejs") %>