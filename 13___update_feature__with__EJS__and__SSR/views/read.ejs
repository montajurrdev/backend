<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Read</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
      <script src="https://cdn.tailwindcss.com"></script> 
</head>
<body>
        <div class=" w-full h-full  bg-zinc-900 text-white p-10">
            <div class="nav mb-10">
                <a class="text-blue-500" href="/">Back to Home</a>
            </div>
        <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>

        <div class="users  flex gap-3 flex-wrap">
            <% if(users.length > 0){ %>
<% users.forEach((user)=>{ %>
            <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                <div class="w-full h-52 rounded-lg bg-zinc-700 overflow-hidden">
                    <img class="w-full h-full object-cover object-top" src="<%= user.image %>" alt="something">
                </div>
                <h3 class="text-xl tarcking-tighter mt-3"><%= user.name %></h3>
                <h5 class="text-zinc-500"><%= user.email %></h5>
                <div class="flex gap-3">
                    <a class="text-zinc-300" href="/edit/<%= user._id %>">Edit User</a>
                    <a class="text-red-500" href="/delete/<%= user._id %>">Delete User</a>
                </div>
            </div>
            <% }) %>
            <% } else{ %>
                <h3 class="text-zinc-500">no users yet.</h3>
            <% } %>
            

        </div>

    </div>
</body>
</html>